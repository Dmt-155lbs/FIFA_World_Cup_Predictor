# =============================================================================
# Variables de Entorno — Mundial FIFA 2026 Predictor
# =============================================================================
# INSTRUCCIONES:
#   1. Copiar este archivo como .env:  cp .env.example .env
#   2. Reemplazar los valores por defecto con tus credenciales reales
#   3. NUNCA subir .env al repositorio (está en .gitignore)
# =============================================================================

# --- Base de Datos (SQL Server 2022) ---
DB_SA_PASSWORD=TuPasswordSeguro123!

# --- API Externa (The Odds API) ---
ODDS_API_KEY=tu_api_key_aqui

# --- MLflow ---
MLFLOW_TRACKING_URI=http://mlflow:5000

# --- Alertas / Monitoreo ---
# Webhook entrante de Slack o Discord para alertas de degradación/fallos.
# Si se deja vacío, las alertas solo se registran en el log estructurado.
WEBHOOK_URL=

# --- Python ---
PYTHONPATH=/app
